<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd" >
<suite name="Business Workflows Suite" verbose="1">

    <test name="Workflow Execution">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.eliasnogueira.workflow.BrowserInitializationWorkflow"/>
            <class name="com.eliasnogueira.workflow.UserLoginWorkflow"/>
            <class name="com.eliasnogueira.workflow.UserLogoutWorkflow"/>
            <class name="com.eliasnogueira.workflow.SearchWorkflow"/>
            <class name="com.eliasnogueira.workflow.UserRegistrationWorkflow"/>
            <class name="com.eliasnogueira.workflow.BookingValidationWorkflow"/>
            <class name="com.eliasnogueira.workflow.RoomBookingWorkflow"/>
            <class name="com.eliasnogueira.workflow.BookingWorkflow"/>
        </classes>
    </test>

</suite>
